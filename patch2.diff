	c *call[V],
	key K,
	fn func(context.Context) (V, error),
	ctx context.Context,
) (shared bool, doneNil bool) {
	defer func() {
		if r := recover(); r != nil {
			c.panicErr = &panicError{value: r, stack: debug.Stack()}
		}

